# Sales Data Analysis

# 1. Import libraries
import pandas as pd
import matplotlib.pyplot as plt

# 2. Load data
df = pd.DataFrame({
    'month': [1, 2, 3, 4, 5],
    'product': ['A', 'A', 'B', 'B', 'A'],
    'revenue': [1000, 1200, 1500, 1700, 1600]
})

# 3. Exploratory Data Analysis
print(df.head())
print(df.describe())

# 4. Revenue by month
sales_by_month = df.groupby('month')['revenue'].sum()
print(sales_by_month)

# 5. Visualization
sales_by_month.plot()
plt.title("Revenue by Month")
plt.xlabel("Month")
plt.ylabel("Revenue")
plt.show()

# 6. Top products
top_products = df.groupby('product')['revenue'].sum().sort_values(ascending=False)
print(top_products)

# 7. Conclusion
# - Revenue changes over time
# - Some products generate more revenue
# - Data aggregation helps identify trends
